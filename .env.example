# ──────────────────────────────────────────
#  WES Backend — Variables de entorno
#  Copia este archivo a .env y completa los valores
# ──────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# Base de datos (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh
JWT_REFRESH_EXPIRES_IN=7d

# Credenciales del agente (usuario único en Fase 1)
ADMIN_EMAIL=admin@wesagencia.com
ADMIN_PASSWORD=cambia_esto_antes_de_deploy

# n8n — Webhook para envío de WhatsApp
N8N_WEBHOOK_URL=https://tu-n8n.com/webhook/wes-whatsapp
N8N_WEBHOOK_SECRET=secreto_compartido_con_n8n

# CORS — Origen del frontend
FRONTEND_URL=https://app.wesagencia.com
